# Copie este arquivo para .env e preencha com seus dados

# === EVOLUTION API (WhatsApp) ===
# URL da sua Evolution API no Railway (preenchida automaticamente após deploy)
EVOLUTION_API_URL=https://sua-evolution-api.railway.app

# Chave de API — você define essa senha na hora de criar a Evolution API
EVOLUTION_API_KEY=sua_chave_secreta_aqui

# Nome da instância (pode ser qualquer nome, sem espaços)
EVOLUTION_INSTANCE=corre-pro-cupom

# ID do Canal do WhatsApp
# Para pegar: abra o Canal no WhatsApp Web → inspecione o elemento → procure o JID
# Formato: 120363XXXXXXXXXX@newsletter
WA_CHANNEL_ID=

# IDs dos Grupos separados por vírgula
# Para pegar: Evolution API → GET /group/fetchAllGroups/{instance}
# Formato: 5511999999999-XXXXXXXXXX@g.us,5511888888888-YYYYYYYYYY@g.us
WA_GROUP_IDS=

# === MERCADO LIVRE AFILIADOS ===
ML_AFFILIATE_ID=CC20260615212332

# === CONFIGURAÇÕES DE POSTAGEM ===
POSTING_INTERVAL_MINUTES=30
START_HOUR=8
END_HOUR=22

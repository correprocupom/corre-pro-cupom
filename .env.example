# Copie este arquivo para .env e preencha com seus dados

# === TELEGRAM ===
# Crie um bot no @BotFather e cole o token aqui
TELEGRAM_BOT_TOKEN=seu_token_aqui

# ID do seu canal Telegram (ex: @canal_ofertas_esporte ou -1001234567890)
TELEGRAM_CHANNEL_ID=@seu_canal_aqui

# === MERCADO LIVRE AFILIADOS ===
# Seu ID de afiliado (encontrado no painel afiliados.mercadolivre.com.br)
ML_AFFILIATE_ID=seu_id_afiliado_aqui

# === CONFIGURAÇÕES ===
# Intervalo entre postagens em minutos (ex: 30 = posta a cada 30 min)
POSTING_INTERVAL_MINUTES=30

# Horário de início das postagens (formato 24h)
START_HOUR=8

# Horário de fim das postagens
END_HOUR=22
